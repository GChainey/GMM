# Copy this file to `.env.local` and fill in real values there.
# Never commit real secrets — `.env.local` is gitignored, `.env.example` is not.

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Clerk redirect URLs (defaults are fine for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Neon Postgres — https://console.neon.tech → connection string (pooled)
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Vercel Blob — https://vercel.com/dashboard/stores → create Blob store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Public site URL (used in absolute redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode — auto-on when NODE_ENV !== "production". Set to "1" to force on
# (e.g. on a preview deployment), or "0" to force off (e.g. local "real" mode).
# When on, a ⌘K drawer surfaces time-travel + seed controls and the Demo
# Council is auto-founded for the signed-in user on first load.
# NEXT_PUBLIC_DEMO_MODE=1
